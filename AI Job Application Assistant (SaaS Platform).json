        "googlePalmApi": {
          "id": "HxU9Wq5zIVyxXcjS",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const output = $json.text;\n\nconst coverLetter = output\n  .split(\"===RESUME_SUMMARY===\")[0]\n  .replace(\"===COVER_LETTER===\", \"\")\n  .trim();\n\nconst resumeSummary = output\n  .split(\"===RESUME_SUMMARY===\")[1]\n  .trim();\n\nreturn {\n  coverLetter,\n  resumeSummary,\n};"
      },
      "type": "n8n-nodes-base.code",
