    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an expert HR recruiter, ATS resume writer, and career consultant.\n\nYou will receive a candidate's resume and a job description.\n\nCandidate Name:\n{{ $('Webhook').item.json.body.fullName }}\n\nResume:\n{{ $json.text }}\n\nJob Description:\n{{ $('Webhook').item.json.body.jobDescription }}\n\nInstructions:\n- Analyze both the resume and the job description carefully.\n- Never invent skills, experience, education, certifications, or achievements that are not present in the resume.\n- Tailor the cover letter specifically to the job description.\n- Write a professional, human-like cover letter.\n- Create a concise ATS-friendly resume summary based only on the resume.\n- Use clear, professional English.\n\nReturn ONLY in the following format exactly:\n\n===COVER_LETTER===\n<cover letter>\n\n===RESUME_SUMMARY===\n<resume summary>\n\nDo not include any other text, explanations, markdown, headings, or code blocks.",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        448,
        -64
      ],
